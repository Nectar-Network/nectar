# ── Keeper operator keypairs ──────────────────────────────────────────────────
# Primary keeper secret key (used by keeper-alpha)
KEEPER_SECRET=SABC...

# Two-keeper docker-compose mode
KEEPER_A_SECRET=SABC...
KEEPER_B_SECRET=SABC...

# Display name for this keeper instance
KEEPER_NAME=keeper-alpha

# ── Deployed contract addresses ───────────────────────────────────────────────
# Run ./scripts/testnet-setup.sh to populate these automatically
USDC_CONTRACT=CXXX...        # deployed mock USDC token
REGISTRY_CONTRACT=CXXX...   # KeeperRegistry contract
VAULT_CONTRACT=CYYY...       # NectarVault contract

# Blend pool to monitor for liquidations. Three valid choices:
#   1. Blend testnet V2 (official, live): CCEBVDYM32YNYCVNRXQKDFFPISJJCV557CDZEIRBEE4NCV4KHPQ44HGF
#      Source: github.com/blend-capital/blend-utils → testnet.contracts.json (TestnetV2)
#   2. LiquidationLab (in-repo Blend-compatible test pool — set BLEND_POOL to the
#      address printed by tranche-1-e2e.sh if/when LiquidationLab is deployed)
#   3. Leave empty — keeper runs in vault-monitor-only mode (API still serves,
#      no liquidation cycle)
BLEND_POOL=CCEBVDYM32YNYCVNRXQKDFFPISJJCV557CDZEIRBEE4NCV4KHPQ44HGF

# ── DEX (collateral → USDC conversion after auction fills) ────────────────────
# Soroswap is the primary venue, Phoenix the fallback. Leave a router empty to
# disable that venue. With no DEX configured the keeper holds non-USDC collateral
# rather than synthesizing proceeds.
# Soroswap router (testnet, verified from soroswap/core public/testnet.contracts.json):
SOROSWAP_ROUTER=CCJUD55AG6W5HAI5LRVNKAE5WDP5XGZBUDS5WNTIVDU7O264UZZE7BRD
# Phoenix has no public testnet deployment; set to an XYK pool (pair) contract
# for the collateral/USDC pair if available, else leave empty.
# PHOENIX_ROUTER=CXXX...
# Max swap slippage in basis points (100 = 1%, default 100, range 0–10000)
# SLIPPAGE_BPS=100

# ── Network config (defaults to Soroban Testnet) ──────────────────────────────
# SOROBAN_RPC=https://soroban-testnet.stellar.org:443
# NETWORK_PASSPHRASE=Test SDF Network ; September 2015
# HORIZON_URL=https://horizon-testnet.stellar.org

# ── Tuning ────────────────────────────────────────────────────────────────────
# POLL_INTERVAL=10        # seconds between keeper cycles (min 3, max 300)
# MIN_PROFIT=1.02         # minimum lot/bid ratio to fill (must be > 0)

# ── Deploy scripts ────────────────────────────────────────────────────────────
# ADMIN_SECRET=SABC...    # Stellar secret for deploying contracts
# ADMIN_ADDRESS=GABC...   # Corresponding public key

# ── Frontend (frontend/.env.local) ────────────────────────────────────────────
# All four are referenced in frontend/lib/stellar.ts and frontend/app/vault/.
# After ./scripts/tranche-1-e2e.sh, copy the IDs from .env into these.
# NEXT_PUBLIC_API_URL=http://localhost:8080
# NEXT_PUBLIC_REGISTRY_CONTRACT=CXXX...
# NEXT_PUBLIC_VAULT_CONTRACT=CYYY...
# NEXT_PUBLIC_USDC_CONTRACT=CZZZ...

# ── Performance page (comma-separated list of depositor addresses) ─────────────
# KNOWN_DEPOSITORS=GABC...,GDEF...,GHIJ...
# USER_01_ADDRESS=GABC...
# USER_02_ADDRESS=GDEF...
# ... (15 users generated by scripts/gen-wallets.sh)
# USER_15_ADDRESS=GXYZ...
